# Normalize line endings in the repo and keep code as LF across platforms.
# This prevents "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Source / config files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.py   text eol=lf

# Shell scripts
*.sh   text eol=lf

# Windows scripts
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Treat common binaries as binary (no newline conversions)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.sqlite3 binary
